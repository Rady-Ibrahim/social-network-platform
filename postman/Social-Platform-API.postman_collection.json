								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"content\": \"Updated post content\"\n}"
						},
						"url": "{{base_url}}/api/posts/{{post_id}}"
					}
				},
				{
					"name": "Delete Post",
