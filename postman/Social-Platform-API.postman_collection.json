							}
						],
						"url": {
							"raw": "{{base_url}}/api/posts?page=1",
							"host": ["{{base_url}}"],
							"path": ["api", "posts"],
							"query": [
								{"key": "page", "value": "1"}
							]
						}
					}
				},
				{
					"name": "Create Post",
					"request": {
